                "low",
                "medium",
                "high",
                "critical"
              ]
            }
          }
        },
        "example_input": {
          "language": "javascript",
          "source": "export const sum = (a, b) => a + b;",
          "focus_areas": [
            "correctness",
            "maintainability"
          ],
