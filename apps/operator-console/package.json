{
  "name": "genesis-operator-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only local Operator Console for Genesis. Visualization only; the Genesis CLI is the sole mutation engine.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --noEmit && vite build",
    "start": "node server/start.mjs",
    "test": "node --test server/tests/*.test.mjs",
    "seed-demo": "node scripts/seed-demo-workspace.mjs"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "5.6.3",
    "vite": "8.1.5"
  }
}
