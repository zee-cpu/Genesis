{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/records/constitutional-amendment.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["id", "record_type", "schema_version", "policy_version", "created_at", "updated_at", "owner", "affected_business", "status", "evidence_references", "related_records", "privacy_classification", "immutable_history_refs", "changed_policy_paths", "rationale", "human_approval_reference", "compatibility_result", "previous_version", "new_version", "effective_date", "is_exception", "exception_expiry", "rollback_version"],
  "properties": {
    "id": { "$ref": "#/$defs/id" }, "record_type": { "const": "constitutional_amendment" },
    "schema_version": { "$ref": "#/$defs/semver" }, "policy_version": { "enum": ["2.0.0", "2.0.1"] },
    "created_at": { "$ref": "#/$defs/dateTime" }, "updated_at": { "$ref": "#/$defs/dateTime" },
    "owner": { "const": "human_authority" }, "affected_business": { "$ref": "#/$defs/nonempty" },
    "status": { "enum": ["draft", "active", "closed", "superseded"] },
    "evidence_references": { "$ref": "#/$defs/nonemptyRefs" }, "related_records": { "$ref": "#/$defs/recordRefs" },
    "privacy_classification": { "$ref": "#/$defs/privacy" }, "immutable_history_refs": { "$ref": "#/$defs/nonemptyRefs" },
    "example_only": { "type": "boolean" }, "changed_policy_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^/" } },
    "rationale": { "$ref": "#/$defs/nonempty" }, "human_approval_reference": { "$ref": "#/$defs/recordRef" },
    "compatibility_result": { "enum": ["passed", "failed"] }, "previous_version": { "$ref": "#/$defs/semver" },
    "new_version": { "$ref": "#/$defs/semver" }, "effective_date": { "$ref": "#/$defs/dateTime" },
    "is_exception": { "type": "boolean" }, "exception_expiry": { "type": ["string", "null"], "format": "date-time" },
    "rollback_version": { "$ref": "#/$defs/semver" }
  },
  "allOf": [
    {
      "if": { "properties": { "is_exception": { "const": true } }, "required": ["is_exception"] },
      "then": { "properties": { "exception_expiry": { "type": "string", "format": "date-time" } } }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }, "recordRef": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }, "dateTime": { "type": "string", "format": "date-time" },
    "nonempty": { "type": "string", "minLength": 1 }, "recordRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/recordRef" } },
    "nonemptyRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonempty" } },
    "privacy": { "enum": ["public", "internal", "confidential", "restricted"] }
  }
}
