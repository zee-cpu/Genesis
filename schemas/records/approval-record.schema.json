{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/records/approval-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "record_type", "schema_version", "policy_version", "created_at", "updated_at", "owner", "affected_business", "status", "evidence_references", "related_records", "privacy_classification", "immutable_history_refs", "approver_role", "approver_principal_id", "requester", "actor", "action_class", "scope", "evidence_snapshot", "limits", "decision", "rationale", "issued_at", "effective_at", "expires_at", "review_at", "revoked", "revocation_reference"],
  "properties": {
    "id": { "$ref": "#/$defs/id" }, "record_type": { "const": "approval_record" },
    "schema_version": { "$ref": "#/$defs/semver" }, "policy_version": { "const": "2.0.0" },
    "created_at": { "$ref": "#/$defs/dateTime" }, "updated_at": { "$ref": "#/$defs/dateTime" },
    "owner": { "$ref": "#/$defs/nonempty" }, "affected_business": { "$ref": "#/$defs/nonempty" },
    "status": { "enum": ["draft", "active", "closed", "revoked", "superseded"] },
    "evidence_references": { "$ref": "#/$defs/nonemptyRefs" }, "related_records": { "$ref": "#/$defs/refs" },
    "privacy_classification": { "$ref": "#/$defs/privacy" }, "immutable_history_refs": { "$ref": "#/$defs/nonemptyRefs" },
    "example_only": { "type": "boolean" },
    "approver_role": { "enum": ["human_authority", "ceo"] }, "approver_principal_id": { "$ref": "#/$defs/nonempty" },
    "requester": { "$ref": "#/$defs/nonempty" }, "actor": { "$ref": "#/$defs/nonempty" },
    "action_class": { "enum": ["routine", "micro_experiment", "experiment", "major_bet", "protected_action", "constitutional_action"] },
    "scope": {
      "type": "object", "additionalProperties": false, "required": ["actions", "wildcard"],
      "properties": { "actions": { "$ref": "#/$defs/nonemptyRefs" }, "wildcard": { "type": "boolean" } }
    },
    "evidence_snapshot": { "$ref": "#/$defs/nonemptyRefs" },
    "limits": {
      "type": "object", "additionalProperties": false,
      "required": ["cash_usd", "labor_hours", "duration_days", "data_classes", "risk_level"],
      "properties": {
        "cash_usd": { "type": "number", "minimum": 0 }, "labor_hours": { "type": "number", "minimum": 0 },
        "duration_days": { "type": "integer", "minimum": 0 }, "data_classes": { "$ref": "#/$defs/dataClasses" },
        "risk_level": { "enum": ["low", "medium", "high", "critical"] }
      }
    },
    "decision": { "enum": ["approved", "denied"] }, "rationale": { "$ref": "#/$defs/nonempty" },
    "issued_at": { "$ref": "#/$defs/dateTime" }, "effective_at": { "$ref": "#/$defs/dateTime" },
    "expires_at": { "$ref": "#/$defs/dateTime" }, "review_at": { "$ref": "#/$defs/dateTime" },
    "revoked": { "type": "boolean" }, "revocation_reference": { "type": ["string", "null"], "minLength": 1 }
  },
  "allOf": [
    { "if": { "properties": { "revoked": { "const": true } }, "required": ["revoked"] }, "then": { "properties": { "revocation_reference": { "type": "string", "minLength": 1 } } } },
    { "if": { "properties": { "approver_role": { "const": "human_authority" } }, "required": ["approver_role"] }, "then": { "properties": { "approver_principal_id": { "const": "genesis-owner" } } } }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }, "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "dateTime": { "type": "string", "format": "date-time" }, "nonempty": { "type": "string", "minLength": 1 },
    "refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/nonempty" } },
    "nonemptyRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonempty" } },
    "dataClasses": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/privacy" } },
    "privacy": { "enum": ["public", "internal", "confidential", "restricted"] }
  }
}
