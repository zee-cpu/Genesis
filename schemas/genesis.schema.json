{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/genesis.schema.json",
  "title": "Genesis policy manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "schema_version",
    "authority",
    "effective_date",
    "human_authority_principal_id",
    "policies",
    "record_templates",
    "documents",
    "validation"
  ],
  "properties": {
    "$schema": {
      "const": "./schemas/genesis.schema.json"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "schema_version": {
      "$ref": "#/$defs/semver"
    },
    "authority": {
      "const": "normative"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "human_authority_principal_id": {
      "type": "string",
      "minLength": 1
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/policyDescriptor"
      }
    },
    "record_templates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/policyDescriptor"
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/documentDescriptor"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "reject_duplicate_yaml_keys",
        "reject_unknown_schema_properties",
        "require_all_references",
        "require_document_version_markers"
      ],
      "properties": {
        "fail_closed": {
          "type": "boolean"
        },
        "reject_duplicate_yaml_keys": {
          "type": "boolean"
        },
        "reject_unknown_schema_properties": {
          "type": "boolean"
        },
        "require_all_references": {
          "type": "boolean"
        },
        "require_document_version_markers": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "nonemptyString": {
      "type": "string",
      "minLength": 1
    },
    "policyDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "schema"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonemptyString"
        },
        "path": {
          "$ref": "#/$defs/nonemptyString"
        },
        "schema": {
          "$ref": "#/$defs/nonemptyString"
        }
      }
    },
    "documentDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "authority",
        "required_policy_version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonemptyString"
        },
        "path": {
          "$ref": "#/$defs/nonemptyString"
        },
        "authority": {
          "const": "explanatory"
        },
        "required_policy_version": {
          "$ref": "#/$defs/semver"
        }
      }
    }
  }
}
