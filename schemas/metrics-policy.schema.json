{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/metrics-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "policy_version", "metrics", "genesis_experiment_001"],
  "properties": {
    "id": { "const": "metrics_policy" },
    "policy_version": { "$ref": "#/$defs/semver" },
    "metrics": {
      "type": "array", "minItems": 11, "maxItems": 11, "items": { "$ref": "#/$defs/metric" }
    },
    "genesis_experiment_001": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "objective", "pre_use_required", "baseline_period", "comparator", "adjudicator", "excluded_success_measures", "metric_ids"],
      "properties": {
        "id": { "const": "genesis_experiment_001" },
        "objective": { "const": "determine_whether_genesis_improves_decision_quality" },
        "pre_use_required": { "const": true },
        "baseline_period": { "$ref": "#/$defs/nonempty" },
        "comparator": { "$ref": "#/$defs/nonempty" },
        "adjudicator": { "const": "human_authority" },
        "excluded_success_measures": { "const": ["documentation_volume"] },
        "metric_ids": { "type": "array", "minItems": 11, "maxItems": 11, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } }
      }
    }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "identifier": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "nonempty": { "type": "string", "minLength": 1 },
    "metric": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "formula", "unit", "population", "denominator", "source", "cadence", "owner", "baseline", "target", "guardrails"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "formula": { "$ref": "#/$defs/nonempty" },
        "unit": { "$ref": "#/$defs/nonempty" },
        "population": { "$ref": "#/$defs/nonempty" },
        "denominator": { "$ref": "#/$defs/nonempty" },
        "source": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonempty" } },
        "cadence": { "$ref": "#/$defs/nonempty" },
        "owner": { "$ref": "#/$defs/identifier" },
        "baseline": { "$ref": "#/$defs/nonempty" },
        "target": { "$ref": "#/$defs/nonempty" },
        "guardrails": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonempty" } }
      }
    }
  }
}
