{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/organization.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "policy_version", "roles", "separation_of_duties", "escalation"],
  "properties": {
    "id": { "const": "organization" },
    "policy_version": { "$ref": "#/$defs/semver" },
    "roles": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/role" },
      "allOf": [
        { "contains": { "type": "object", "required": ["id"], "properties": { "id": { "const": "human_authority" } } } },
        { "contains": { "type": "object", "required": ["id"], "properties": { "id": { "const": "ceo" } } } },
        { "contains": { "type": "object", "required": ["id"], "properties": { "id": { "const": "research" } } } },
        { "contains": { "type": "object", "required": ["id"], "properties": { "id": { "const": "builder" } } } },
        { "contains": { "type": "object", "required": ["id"], "properties": { "id": { "const": "operator" } } } },
        { "contains": { "type": "object", "required": ["id"], "properties": { "id": { "const": "analyst" } } } }
      ]
    },
    "separation_of_duties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposer_must_differ_from_approver", "action_classes"],
      "properties": {
        "proposer_must_differ_from_approver": { "const": true },
        "action_classes": {
          "const": ["major_bet", "protected_action", "permission_escalation", "constitutional_action"]
        }
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ambiguity_target", "policy_conflict_target", "material_risk_target", "protected_action_target"],
      "properties": {
        "ambiguity_target": { "$ref": "#/$defs/roleId" },
        "policy_conflict_target": { "$ref": "#/$defs/roleId" },
        "material_risk_target": { "$ref": "#/$defs/roleId" },
        "protected_action_target": { "$ref": "#/$defs/roleId" }
      }
    }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "roleId": { "enum": ["human_authority", "ceo", "research", "builder", "operator", "analyst"] },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "principal_type", "reports_to", "escalates_to", "accountabilities"],
      "properties": {
        "id": { "$ref": "#/$defs/roleId" },
        "principal_type": { "enum": ["human", "human_or_agent"] },
        "reports_to": { "oneOf": [{ "$ref": "#/$defs/roleId" }, { "type": "null" }] },
        "escalates_to": { "oneOf": [{ "$ref": "#/$defs/roleId" }, { "type": "null" }] },
        "accountabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
